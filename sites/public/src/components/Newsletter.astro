---
// Editorial-style newsletter card — sign up for Buttondown.
// To activate: sign up at https://buttondown.com (free up to 100 subs)
// then replace BUTTONDOWN_USERNAME below with your handle.
const BUTTONDOWN_USERNAME = "YOUR_USERNAME_HERE";
const isPlaceholder = BUTTONDOWN_USERNAME === "YOUR_USERNAME_HERE";
---

<aside class="editorial-newsletter">
    <div class="rule-thick"></div>

    <div class="newsletter-grid">
        <div class="badge-side">
            <em>Postal<br />Edition<br />— weekly</em>
        </div>

        <div class="newsletter-body">
            <h3 class="nl-headline">새 글이 도착하면<br /><span class="nl-script">알려드릴게요</span></h3>

            <p class="nl-lede">
                AI · 콘텐츠 · 개발에 대한 글을 매주 한 통 메일로 보내드립니다.
                <em>광고 없음. 언제든 구독 취소.</em>
            </p>

            {isPlaceholder ? (
                <div class="placeholder-warning">
                    뉴스레터 비활성화 상태 — Buttondown 가입 후 <code>src/components/Newsletter.astro</code>의 <code>BUTTONDOWN_USERNAME</code>을 본인 핸들로 변경하세요.
                </div>
            ) : (
                <form
                    action={`https://buttondown.com/api/emails/embed-subscribe/${BUTTONDOWN_USERNAME}`}
                    method="post"
                    target="popupwindow"
                    onsubmit={`window.open('https://buttondown.com/${BUTTONDOWN_USERNAME}', 'popupwindow')`}
                    class="nl-form"
                >
                    <input
                        type="email"
                        name="email"
                        placeholder="your@email.com"
                        required
                        class="nl-input"
                    />
                    <button type="submit" class="nl-submit">SUBSCRIBE →</button>
                </form>
            )}
        </div>

        <div class="badge-side badge-right">
            <em>since<br />2026<br />issue 001</em>
        </div>
    </div>

    <div class="rule-thin"></div>
</aside>

<style>
.editorial-newsletter {
    background: var(--paper);
    background-image: radial-gradient(rgba(0,0,0,.012) 1px, transparent 1px);
    background-size: 3px 3px;
    padding: 24px 40px 32px;
    margin: 32px 0;
    color: var(--ink);
}

.rule-thick {
    height: 3px;
    background: var(--ink);
    margin-bottom: 24px;
}
.rule-thin {
    height: 1px;
    background: var(--rule);
    margin-top: 24px;
}

.newsletter-grid {
    display: grid;
    grid-template-columns: 90px 1fr 90px;
    gap: 24px;
    align-items: start;
}

.badge-side {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 11px;
    line-height: 1.4;
    color: var(--muted);
    border-top: 1px solid var(--ink);
    padding-top: 6px;
}
.badge-right { text-align: right; }

.newsletter-body { text-align: center; }

.nl-headline {
    font-family: var(--font-serif-sc);
    font-weight: 700;
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: var(--headline-tracking);
    line-height: 1.05;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0 0 16px;
}
.nl-script {
    font-family: var(--font-script);
    font-weight: 400;
    text-transform: none;
    font-size: 1.1em;
    color: var(--ink);
    letter-spacing: 0;
}

.nl-lede {
    font-family: var(--font-serif);
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 50ch;
    margin: 0 auto 20px;
}
.nl-lede em { color: var(--muted); font-style: italic; }

.nl-form {
    display: flex;
    gap: 0;
    max-width: 480px;
    margin: 0 auto;
    border: 1px solid var(--ink);
}

.nl-input {
    flex: 1;
    padding: 10px 14px;
    background: var(--paper);
    border: none;
    outline: none;
    font-family: var(--font-serif);
    font-size: 14px;
    color: var(--ink);
}
.nl-input::placeholder {
    color: var(--muted);
    font-style: italic;
}

.nl-submit {
    padding: 10px 20px;
    background: var(--ink);
    color: var(--paper);
    border: none;
    font-family: var(--font-label);
    font-size: 11px;
    letter-spacing: var(--label-tracking);
    text-transform: uppercase;
    cursor: pointer;
    transition: background .15s;
}
.nl-submit:hover { background: var(--muted); }

.placeholder-warning {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 12px;
    color: var(--muted);
    border: 1px dashed var(--muted);
    padding: 12px 16px;
    max-width: 540px;
    margin: 0 auto;
}
.placeholder-warning code {
    background: var(--paper-deep);
    padding: 1px 4px;
    font-family: ui-monospace, monospace;
    font-size: 11px;
    font-style: normal;
}

@media (max-width: 720px) {
    .editorial-newsletter { padding: 16px 20px 24px; }
    .newsletter-grid {
        grid-template-columns: 1fr;
        gap: 16px;
    }
    .badge-side, .badge-right {
        text-align: center;
        border-top: none;
    }
    .nl-form { flex-direction: column; }
    .nl-input { border-bottom: 1px solid var(--ink); }
}
</style>
