---
// Swiss minimal newsletter — flat form, hairline rules, type-led.
// To activate: sign up at https://buttondown.com (free up to 100 subs)
// then replace BUTTONDOWN_USERNAME below with your handle.
const BUTTONDOWN_USERNAME = "YOUR_USERNAME_HERE";
const isPlaceholder = BUTTONDOWN_USERNAME === "YOUR_USERNAME_HERE";
---

<aside id="newsletter" class="swiss-newsletter">
    <div class="rule-top"></div>

    <div class="grid">
        <div class="meta">
            <span class="meta-label">Section</span>
            <span class="meta-value">Subscribe</span>
        </div>

        <div class="body">
            <h2 class="headline">Get new posts in your inbox.</h2>
            <p class="lede">
                A short letter every week or so. AI, business, teaching, writing.
                No ads, no fluff. Unsubscribe any time.
            </p>

            {isPlaceholder ? (
                <div class="placeholder">
                    Newsletter is inactive. Configure <code>BUTTONDOWN_USERNAME</code> in <code>src/components/Newsletter.astro</code> after signing up at <a href="https://buttondown.com">buttondown.com</a>.
                </div>
            ) : (
                <form
                    action={`https://buttondown.com/api/emails/embed-subscribe/${BUTTONDOWN_USERNAME}`}
                    method="post"
                    target="popupwindow"
                    onsubmit={`window.open('https://buttondown.com/${BUTTONDOWN_USERNAME}', 'popupwindow')`}
                    class="form"
                >
                    <input
                        type="email"
                        name="email"
                        placeholder="your@email.com"
                        required
                        class="input"
                    />
                    <button type="submit" class="submit">Subscribe →</button>
                </form>
            )}
        </div>

        <div class="meta meta-right">
            <span class="meta-label">Frequency</span>
            <span class="meta-value">weekly</span>
        </div>
    </div>

    <div class="rule-bot"></div>
</aside>

<style>
.swiss-newsletter {
    background: var(--white);
    color: var(--black);
    padding: 0 32px;
    margin: 48px 0;
}

.rule-top { height: 1px; background: var(--black); }
.rule-bot { height: 1px; background: var(--black); }

.grid {
    display: grid;
    grid-template-columns: 140px 1fr 140px;
    gap: 32px;
    padding: 48px 0;
    align-items: start;
}

.meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
}
.meta-right { text-align: right; align-items: flex-end; }
.meta-label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--gray-400);
}
.meta-value {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: var(--tracking-snug);
    color: var(--black);
}

.body { max-width: 560px; }

.headline {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(28px, 3.5vw, 44px);
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
    color: var(--black);
    margin: 0 0 16px;
}

.lede {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.55;
    letter-spacing: var(--tracking-snug);
    color: var(--gray-600);
    margin: 0 0 24px;
}

.form {
    display: flex;
    gap: 0;
    max-width: 480px;
    border: 1px solid var(--black);
}
.input {
    flex: 1;
    padding: 12px 14px;
    background: var(--white);
    border: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--black);
    letter-spacing: var(--tracking-snug);
}
.input::placeholder { color: var(--gray-400); }

.submit {
    padding: 12px 20px;
    background: var(--black);
    color: var(--white);
    border: none;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: var(--tracking-snug);
    cursor: pointer;
    transition: opacity .15s;
}
.submit:hover { opacity: 0.85; }

.placeholder {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.5;
    color: var(--gray-600);
    border: 1px solid var(--gray-200);
    padding: 14px 16px;
    max-width: 540px;
}
.placeholder code {
    background: var(--gray-50);
    padding: 1px 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--black);
}
.placeholder a {
    color: var(--black);
    text-decoration: underline;
    text-underline-offset: 2px;
}

@media (max-width: 720px) {
    .swiss-newsletter { padding: 0 20px; }
    .grid {
        grid-template-columns: 1fr;
        gap: 16px;
        padding: 32px 0;
    }
    .meta-right { text-align: left; align-items: flex-start; }
    .form { flex-direction: column; max-width: 100%; }
    .input { border-bottom: 1px solid var(--black); }
}
</style>
