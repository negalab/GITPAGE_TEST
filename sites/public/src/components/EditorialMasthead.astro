---
// Swiss minimal masthead — used on the home page only.
import { siteConfig, profileConfig } from "@/config";

const today = new Date();
const issue = String(1).padStart(2, "0");
const year = today.getFullYear();
const dateStr = today.toISOString().slice(0, 10);
---

<header class="swiss-masthead">
    <div class="topline">
        <span class="meta-left swiss-num">№ {issue} / {year}</span>
        <span class="meta-mid">{siteConfig.subtitle}</span>
        <span class="meta-right swiss-num">{dateStr}</span>
    </div>

    <div class="title-block">
        <h1 class="title">{siteConfig.title}</h1>
        <p class="bio">{profileConfig.bio}</p>
    </div>

    <div class="grid-row">
        <div class="col">
            <span class="col-label">section</span>
            <span class="col-value">writing</span>
        </div>
        <div class="col">
            <span class="col-label">section</span>
            <span class="col-value">teaching</span>
        </div>
        <div class="col">
            <span class="col-label">section</span>
            <span class="col-value">making</span>
        </div>
        <div class="col">
            <span class="col-label">subscribe</span>
            <span class="col-value"><a href="#newsletter">→ email</a></span>
        </div>
    </div>
</header>

<style>
.swiss-masthead {
    background: var(--white);
    color: var(--black);
    padding: 16px 32px 0;
    margin-bottom: 32px;
    border-bottom: 1px solid var(--black);
}

.topline {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    align-items: baseline;
    border-top: 1px solid var(--black);
    border-bottom: 1px solid var(--black);
    padding: 8px 0;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--black);
}
.meta-left { text-align: left; }
.meta-mid {
    text-align: center;
    text-transform: none;
    letter-spacing: var(--tracking-snug);
    color: var(--gray-600);
    font-size: 12px;
}
.meta-right { text-align: right; }

.title-block {
    padding: 72px 0 48px;
    max-width: 720px;
}
.title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(56px, 11vw, 144px);
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: var(--black);
    margin: 0 0 24px;
}
.bio {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: clamp(17px, 1.6vw, 21px);
    line-height: 1.4;
    letter-spacing: var(--tracking-snug);
    color: var(--gray-600);
    max-width: 56ch;
    margin: 0;
}

.grid-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding: 24px 0;
    border-top: 1px solid var(--black);
}
.col {
    display: flex;
    flex-direction: column;
    gap: 4px;
}
.col-label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--gray-400);
}
.col-value {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: var(--tracking-snug);
    color: var(--black);
}
.col-value a {
    color: var(--black);
    text-decoration: none;
    border-bottom: 1px solid var(--black);
    transition: opacity .15s;
}
.col-value a:hover { opacity: 0.5; }

@media (max-width: 720px) {
    .swiss-masthead { padding: 12px 20px 0; }
    .topline {
        grid-template-columns: 1fr 1fr;
        font-size: 10px;
    }
    .meta-mid { display: none; }
    .title-block { padding: 40px 0 32px; }
    .grid-row {
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }
}
</style>
